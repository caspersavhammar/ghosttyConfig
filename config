font-family = "JetBrainsMono Nerd Font Mono"
font-family-bold = "JetBrainsMono NFM Bold"
font-family-italic = "JetBrainsMono NFM Italic"
font-family-bold-italic = "JetBrainsMono NFM Bold Italic"
font-size = 13

theme = Atom One Dark
background = 1E1F20
background-opacity = 0.95
macos-titlebar-style = transparent

window-inherit-working-directory = true
mouse-hide-while-typing = true

gtk-custom-css = tab-style.css

keybind = cmd+t=new_tab
keybind = cmd+n=new_window
keybind = opt+w=close_surface

custom-shader = shaders/cursor_sweep.glsl
