font-family = "JetBrains Mono "
font-family-bold = "JetBrains Mono Bold"
font-family-italic = "JetBrains Mono Italic"
font-family-bold-italic = "JetBrains Mono Bold italic"
font-size = 13
theme = Atom One Dark
background = 1E1F20
background-opacity = 1
background-blur-radius = 20
window-inherit-working-directory = true
mouse-hide-while-typing = true
macos-titlebar-style = 

window-padding-x = 1
window-padding-y = 1
window-padding-balance = true

confirm-close-surface = false
keybind = cmd+t=new_tab
keybind = cmd+n=new_window
keybind = opt+w=close_surface

# custom-shader = shaders/cursor_blaze.glsl
custom-shader = shaders/cursor_smear_fade.glsl
# custom-shader = shaders/cursor_blaze_tapered.glsl
# custom-shader = shaders/cursor_frozen.glsl

